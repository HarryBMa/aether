# ── Matrix homeserver ─────────────────────────────────────────────────────────
MATRIX_HOMESERVER_URL=https://matrix.hospital.se
# Bot user access token (create with: curl -X POST .../v3/login)
MATRIX_ACCESS_TOKEN=syt_xxxxx
MATRIX_DEVICE_ID=CAPTURE_SERVICE
# Long-poll timeout for /sync (ms). 30000 = 30s
MATRIX_SYNC_TIMEOUT_MS=30000
# Comma-separated room IDs to watch. Leave blank to watch all joined rooms.
# Example: !abc123:hospital.se,!def456:hospital.se
MATRIX_WATCHED_ROOMS=

# ── FHIR / COSMIC ─────────────────────────────────────────────────────────────
FHIR_BASE_URL=https://cosmic.hospital.se/fhir/r4
# Paths inside the container (mounted from ./certs)
FHIR_CLIENT_CERT=/certs/fhir-client.pem
FHIR_CLIENT_KEY=/certs/fhir-client-key.pem
FHIR_CA_CERT=/certs/fhir-ca.pem
FHIR_TIMEOUT_MS=15000
FHIR_MAX_RETRIES=3
FHIR_RETRY_DELAY_MS=2000

# ── SITHS step-up auth ────────────────────────────────────────────────────────
# URL of your on-prem SITHS RP (Relying Party) service
SITHS_VERIFY_URL=https://siths-rp.hospital.se
SITHS_RP_CLIENT_CERT=/certs/siths-rp.pem
SITHS_RP_CLIENT_KEY=/certs/siths-rp-key.pem
# Step-up token TTL in milliseconds (default: 10 min)
STEP_UP_TOKEN_TTL_MS=600000

# ── Service authentication ────────────────────────────────────────────────────
# Minimum 32 characters. Generate: openssl rand -hex 32
SERVICE_API_KEY=change_me_use_a_real_secret_at_least_32_chars

# ── Storage ───────────────────────────────────────────────────────────────────
DB_PATH=/data/capture.db
AUDIT_LOG_PATH=/data/audit.ndjson

# ── Image limits ──────────────────────────────────────────────────────────────
# Max image size in bytes (default: 25 MB)
MAX_IMAGE_BYTES=26214400
# How long to keep image in-memory buffer before expiry (ms, default: 30 min)
IMAGE_BUFFER_TTL_MS=1800000

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3400
NODE_ENV=production

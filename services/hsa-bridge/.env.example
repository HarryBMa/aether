# ── HSA LDAP directory ────────────────────────────────────────────────────────
# Production: Inera national catalog via Sjunet
HSA_LDAP_URL=ldaps://katalog.hsa.sjunet.org:636
# Leave blank for anonymous bind (Inera allows anonymous read for hsa-bridge use cases)
HSA_LDAP_BIND_DN=
HSA_LDAP_BIND_PASSWORD=
HSA_LDAP_BASE_DN=ou=HSA,o=Inera,c=SE
# Path to Inera's LDAP CA cert (download from Inera)
HSA_LDAP_TLS_CA=/certs/inera-ldap-ca.pem
HSA_LDAP_TIMEOUT_MS=5000

# Cache TTL in milliseconds (5 min default)
CACHE_TTL_MS=300000

# ── Matrix ────────────────────────────────────────────────────────────────────
# Your Synapse homeserver domain — used to construct @hsaid:domain Matrix IDs
MATRIX_DOMAIN=matrix.hospital.se

# ── Service auth ──────────────────────────────────────────────────────────────
API_KEY=change_me_use_a_real_secret_at_least_32_chars

PORT=3402
NODE_ENV=production

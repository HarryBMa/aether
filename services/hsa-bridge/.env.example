# ── EK REST API — Region Stockholm (primary lookup) ──────────────────────────
# Elektronisk Katalog: https://www.ek.sll.se
# Contact Region Stockholm IT (STÖD & INFRASTRUKTUR) for API access.
EK_BASE_URL=https://www.ek.sll.se

# API key from Region Stockholm (if required — some endpoints allow mTLS-only auth)
EK_API_KEY=

# mTLS client certificate for Sjunet access (SITHS infrastructure cert)
# These are separate from the practitioner's personal SITHS card —
# they are service/application certificates issued by Inera for the server.
EK_CLIENT_CERT=/certs/sjunet-client.pem
EK_CLIENT_KEY=/certs/sjunet-client-key.pem
# Inera SITHS CA bundle (download from https://www.inera.se/tjanster/siths-ca/)
EK_CA_CERT=/certs/siths-ca-bundle.pem

# ── HSA LDAP — Region Stockholm (fallback) ───────────────────────────────────
# LDAP replica of ek.sll.se — accessible within Sjunet / TakeCare network.
# Used when the EK REST API is unavailable or for bulk lookups.
HSA_LDAP_URL=ldaps://ldap.ek.sll.se:636
# Anonymous bind is allowed for read-only access within Sjunet
HSA_LDAP_BIND_DN=
HSA_LDAP_BIND_PASSWORD=
# Region Stockholm subtree in the national HSA catalog
HSA_LDAP_BASE_DN=ou=Region Stockholm,o=HSA-katalogen,c=SE
HSA_LDAP_TLS_CA=/certs/siths-ca-bundle.pem
HSA_LDAP_TIMEOUT_MS=5000

# ── Cache ─────────────────────────────────────────────────────────────────────
# TTL for cached LDAP/EK results (ms). 5 min default.
# The EK catalog is updated nightly by Inera — 5 min is safe.
CACHE_TTL_MS=300000

# ── Matrix ────────────────────────────────────────────────────────────────────
MATRIX_DOMAIN=matrix.hospital.se

# ── Service auth ──────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
API_KEY=change_me_use_a_real_secret_at_least_32_chars

PORT=3402
NODE_ENV=production

# ── TLS server certificate (the RP's own cert) ──────────────────────────────
TLS_CERT=/certs/siths-rp.pem
TLS_KEY=/certs/siths-rp-key.pem

# ── SITHS CA trust bundle ─────────────────────────────────────────────────────
# Download the current bundle from Inera:
# https://www.inera.se/tjanster/siths-ca/
# Concatenate Root CA + all Issuing CAs into one PEM file.
SITHS_CA_BUNDLE=/certs/siths-ca-bundle.pem

# ── JWT signing keys (EC P-256) ───────────────────────────────────────────────
# Generate:
#   openssl ecparam -name prime256v1 -genkey -noout -out jwt-signing-key.pem
#   openssl ec -in jwt-signing-key.pem -pubout -out jwt-signing-key-pub.pem
JWT_PRIVATE_KEY=/certs/jwt-signing-key.pem
JWT_PUBLIC_KEY=/certs/jwt-signing-key-pub.pem
JWT_TTL_SEC=600
JWT_ISSUER=urn:aether:siths-rp

# ── Service auth ──────────────────────────────────────────────────────────────
# The capture service calls /verify with this key.
# Must match SITHS_RP_API_KEY in the capture service config.
# Generate: openssl rand -hex 32
API_KEY=change_me_use_a_real_secret_at_least_32_chars

# ── Dev / test ────────────────────────────────────────────────────────────────
# Set to false to skip client cert requirement (allows dev without smartcard)
REQUIRE_CLIENT_CERT=true

PORT=3401
NODE_ENV=production

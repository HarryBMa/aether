# ── Platform identity ─────────────────────────────────────────────────────────
# Your Matrix homeserver domain (must match homeserver.yaml server_name)
MATRIX_DOMAIN=matrix.hospital.se

# ── Database ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 24
POSTGRES_PASSWORD=change_me_postgres_password

# ── Service secrets ───────────────────────────────────────────────────────────
# Generate each: openssl rand -hex 32
SITHS_RP_API_KEY=change_me_siths_rp_api_key_32chars
HSA_BRIDGE_API_KEY=change_me_hsa_bridge_api_key_32chars
CAPTURE_API_KEY=change_me_capture_api_key_32chars

# ── Synapse secrets ───────────────────────────────────────────────────────────
# Also set in homeserver.yaml — must match
MACAROON_SECRET=change_me_macaroon_secret
FORM_SECRET=change_me_form_secret
REGISTRATION_SHARED_SECRET=change_me_registration_secret

# ── Matrix access tokens ──────────────────────────────────────────────────────
# Create a bot user and obtain its access token:
#   docker compose run --rm synapse register_new_matrix_user -c /data/homeserver.yaml \
#     -u aether-capture-bot -p <password> --no-admin http://localhost:8008
# Then log in to get the token.
CAPTURE_MATRIX_TOKEN=syt_capture_bot_token_here

# ── FHIR / COSMIC ─────────────────────────────────────────────────────────────
FHIR_BASE_URL=https://cosmic.hospital.se/fhir/r4

# ── HSA LDAP ──────────────────────────────────────────────────────────────────
HSA_LDAP_URL=ldaps://katalog.hsa.sjunet.org:636
HSA_LDAP_BIND_DN=
HSA_LDAP_BIND_PASSWORD=
HSA_LDAP_BASE_DN=ou=HSA,o=Inera,c=SE

# ── Matrix rooms ──────────────────────────────────────────────────────────────
# Comma-separated room IDs for the capture service to watch.
# Leave blank to watch all joined rooms.
MATRIX_WATCHED_ROOMS=

# ── Coturn WebRTC ─────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
COTURN_AUTH_SECRET=change_me_coturn_auth_secret

# ── SITHS ────────────────────────────────────────────────────────────────────
JWT_TTL_SEC=600
JWT_ISSUER=urn:aether:siths-rp
# Set to false for development without smartcard
REQUIRE_CLIENT_CERT=true
